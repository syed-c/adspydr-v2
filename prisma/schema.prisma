generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  avatarUrl         String?
  passwordHash      String?
  role              UserRole  @default(USER)
  plan              Plan      @default(FREE)
  stripeCustomerId  String?   @unique
  stripeSubId       String?
  planExpiresAt     DateTime?
  trialEndsAt       DateTime?
  onboardingDone    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  teamId            String?
  team              Team?     @relation(fields: [teamId], references: [id])
  
  searches          Search[]
  competitors       TrackedCompetitor[]
  alerts            Alert[]
  reports           Report[]
  apiKeys           ApiKey[]
  sessions          Session[]
  accounts          Account[]
  notifications     Notification[]
  usageLogs         UsageLog[]
}

enum UserRole { USER ADMIN }
enum Plan { FREE PRO AGENCY }

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  members   User[]
  logo      String?
  brandColor String?
  brandName  String?
}

model Search {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       String
  companyName  String?
  companyLogo  String?
  industry     String?
  status       SearchStatus @default(PENDING)
  platforms    String[]
  adsFound     Int      @default(0)
  spendTier    SpendTier?
  spendEstLow  Int?
  spendEstHigh Int?
  aiSummary    String?
  aiInsights   Json?
  rawData      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  ads          Ad[]
  competitor   TrackedCompetitor? @relation(fields: [competitorId], references: [id])
  competitorId String?

  @@index([userId])
  @@index([domain])
}

enum SearchStatus { PENDING RUNNING DONE FAILED }
enum SpendTier { VERY_LOW LOW MEDIUM HIGH VERY_HIGH }

model Ad {
  id             String   @id @default(cuid())
  searchId       String
  search         Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  
  platform       Platform
  adId           String
  headline       String?
  body           String?
  callToAction   String?
  destinationUrl String?
  imageUrl       String?
  videoUrl       String?
  startedRunning DateTime?
  stoppedRunning DateTime?
  isActive       Boolean  @default(true)
  daysRunning    Int?
  
  hookType       String?
  targeting      Json?
  
  createdAt      DateTime @default(now())
  
  @@unique([platform, adId])
  @@index([searchId])
  @@index([platform])
}

enum Platform { FACEBOOK GOOGLE TIKTOK LINKEDIN }

model TrackedCompetitor {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      String
  nickname    String?
  companyName String?
  companyLogo String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastChecked DateTime?
  lastNewAd   DateTime?
  
  searches    Search[]
  alerts      Alert[]
  
  @@unique([userId, domain])
  @@index([userId])
}

model Alert {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitorId   String?
  competitor     TrackedCompetitor? @relation(fields: [competitorId], references: [id])
  type           AlertType
  channel        AlertChannel @default(EMAIL)
  frequency      AlertFrequency @default(INSTANT)
  isActive       Boolean     @default(true)
  lastFired      DateTime?
  lastChecked    DateTime?
  config         Json?
  createdAt      DateTime    @default(now())

  @@index([userId])
}

enum AlertType { NEW_AD AD_STOPPED SPEND_INCREASE NEW_COMPETITOR_DOMAIN }
enum AlertChannel { EMAIL SLACK WEBHOOK }
enum AlertFrequency { INSTANT DAILY WEEKLY }

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())
  
  @@index([userId, readAt])
  @@index([userId])
}

model Report {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  status      ReportStatus @default(GENERATING)
  type        ReportType   @default(COMPETITOR_OVERVIEW)
  fileUrl     String?
  config      Json
  isWhiteLabel Boolean    @default(false)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?

  @@index([userId])
}

enum ReportStatus { GENERATING READY FAILED }
enum ReportType { COMPETITOR_OVERVIEW MULTI_COMPETITOR AD_INTELLIGENCE }

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String   @unique
  keyPrefix   String
  lastUsed    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  author      String   @default("Ads SpyDR Team")
  tags        String[]
  seoTitle    String?
  seoDesc     String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChangelogEntry {
  id          String   @id @default(cuid())
  version     String
  title       String
  description String
  type        ChangeType
  publishedAt DateTime @default(now())
}

enum ChangeType { FEATURE IMPROVEMENT BUGFIX }

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
